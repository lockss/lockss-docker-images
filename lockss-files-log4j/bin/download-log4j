_0="$(basename "${0}")"
_D0="$(cd "$(dirname "${0}")" && pwd)"

VER="${1}"

if [ -z "${VER}" ] ; then
  echo "${_0}: no version supplied" >&2
  exit 1
fi

cd "${_D0}/../docker/log4j" \
&& wget `for a in log4j-1.2-api log4j-api log4j-core log4j-slf4j-impl log4j-web ; do echo "https://repo1.maven.org/maven2/org/apache/logging/log4j/${a}/${VER}/${a}-${VER}.jar" ; done`
